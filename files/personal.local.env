DOTFILES_DIR=$HOME/code/repos/dotfiles/
MMDOT_CONFIG_PATH=$HOME/code/repos/dotfiles/mmdot.yml
OBSIDIAN_NOTEBOOK_DIR="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Nodebook"

# Custom Nvim Feature Flags
NVIM_FEATURE_GOFUMPT=true
SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# mise GitHub API token for GitHub release/tool requests.
# Backed by 1Password; intentionally only present on personal/grafana machines.
if command -v op >/dev/null 2>&1; then
  export MISE_GITHUB_TOKEN="${MISE_GITHUB_TOKEN:-$(op read 'op://Private/Github Mise API Token/credential' 2>/dev/null || true)}"
fi
