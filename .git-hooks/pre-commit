#!/bin/sh
# TruffleHog pre-commit hook
# Uses TruffleHog's pre-commit mode to scan staged content only. Verification is
# disabled so provider/API key validation cannot trigger canary tokens.
export TRUFFLEHOG_PRE_COMMIT=1

CONFIG="$HOME/.config/trufflehog/config.yaml"
[ -f "$CONFIG" ] && set -- --config "$CONFIG"

trufflehog git file://. "$@" \
  --trust-local-git-config \
  --no-verification \
  --results=unverified \
  --fail
