# =============================================================================
# Codex Rules
# =============================================================================

# -----------------------------------------------------------------------------
# FORBIDDEN - deny rules (evaluated first)
# -----------------------------------------------------------------------------

prefix_rule(
    pattern=["rm", "-rf"],
    decision="forbidden",
    justification="Destructive recursive delete is never auto-allowed",
)

prefix_rule(
    pattern=["wget"],
    decision="forbidden",
    justification="Downloading arbitrary files is blocked",
)

prefix_rule(
    pattern=["git", "reset", "--hard"],
    decision="forbidden",
    justification="Hard reset discards uncommitted work",
)

# Block reading .env files explicitly
prefix_rule(
    pattern=["cat", ".env"],
    decision="forbidden",
    justification="Do not read .env files containing secrets",
)

prefix_rule(
    pattern=["head", ".env"],
    decision="forbidden",
    justification="Do not read .env files containing secrets",
)

prefix_rule(
    pattern=["tail", ".env"],
    decision="forbidden",
    justification="Do not read .env files containing secrets",
)

# -----------------------------------------------------------------------------
# ALLOW - build tools & task runners
# -----------------------------------------------------------------------------

# Allow all task commands (simpler and safer than partial token matching)
prefix_rule(
    pattern=["task"],
    decision="allow",
    justification="Allow task runner commands",
)

prefix_rule(
    pattern=["make"],
    decision="allow",
    justification="Allow make commands",
)

prefix_rule(
    pattern=["npm", "run"],
    decision="allow",
    justification="Allow npm run scripts",
)

prefix_rule(
    pattern=["mise", "run"],
    decision="allow",
    justification="Allow mise run tasks",
)

# -----------------------------------------------------------------------------
# ALLOW - filesystem & search
# -----------------------------------------------------------------------------

prefix_rule(
    pattern=["mkdir"],
    decision="allow",
    justification="Creating directories is safe",
)

prefix_rule(
    pattern=["fd"],
    decision="allow",
    justification="File discovery",
)

prefix_rule(
    pattern=["find"],
    decision="allow",
    justification="File discovery",
)

prefix_rule(
    pattern=["ls"],
    decision="allow",
    justification="File listing",
)

prefix_rule(
    pattern=["rg"],
    decision="allow",
    justification="Content search",
)

prefix_rule(
    pattern=["grep"],
    decision="allow",
    justification="Content search",
)

prefix_rule(
    pattern=["diff"],
    decision="allow",
    justification="Comparing files",
)

prefix_rule(
    pattern=["cat"],
    decision="allow",
    justification="Reading file contents",
)

prefix_rule(
    pattern=["head"],
    decision="allow",
    justification="Reading file contents",
)

prefix_rule(
    pattern=["tail"],
    decision="allow",
    justification="Reading file contents",
)

prefix_rule(
    pattern=["wc"],
    decision="allow",
    justification="Basic shell utilities",
)

prefix_rule(
    pattern=["which"],
    decision="allow",
    justification="Basic shell utilities",
)

prefix_rule(
    pattern=["pwd"],
    decision="allow",
    justification="Basic shell utilities",
)

prefix_rule(
    pattern=["echo"],
    decision="allow",
    justification="Basic shell utilities",
)

prefix_rule(
    pattern=["jq"],
    decision="allow",
    justification="JSON processing",
)

# -----------------------------------------------------------------------------
# ALLOW - git
# -----------------------------------------------------------------------------

prefix_rule(
    pattern=["git"],
    decision="allow",
    justification="Allow standard git operations (except explicitly denied)",
)

# -----------------------------------------------------------------------------
# ALLOW - GitHub CLI (gh)
# -----------------------------------------------------------------------------

prefix_rule(
    pattern=["gh"],
    decision="allow",
    justification="Allow GitHub CLI usage",
)

# -----------------------------------------------------------------------------
# ALLOW - Go toolchain
# -----------------------------------------------------------------------------

prefix_rule(
    pattern=["go"],
    decision="allow",
    justification="Allow Go toolchain commands",
)

prefix_rule(
    pattern=["gofumpt"],
    decision="allow",
    justification="Go formatting",
)

prefix_rule(
    pattern=["golangci-lint"],
    decision="allow",
    justification="Go linting",
)

prefix_rule(
    pattern=["godoc"],
    decision="allow",
    justification="Go documentation server",
)

# -----------------------------------------------------------------------------
# ALLOW - Gitea CLI (tea)
# -----------------------------------------------------------------------------

prefix_rule(
    pattern=["tea"],
    decision="allow",
    justification="Allow Gitea CLI usage",
)

prefix_rule(
    pattern=["teaapi"],
    decision="allow",
    justification="Allow Gitea API wrapper usage",
)

# -----------------------------------------------------------------------------
# ALLOW - custom tools
# -----------------------------------------------------------------------------

prefix_rule(
    pattern=["hive"],
    decision="allow",
    justification="Hive context and session management",
)

prefix_rule(
    pattern=["ctx"],
    decision="allow",
    justification="Context management CLI",
)

prefix_rule(
    pattern=["bd"],
    decision="allow",
    justification="Beads work tracking CLI",
)
