prefix_rule(pattern=["hive", "msg"], decision="allow")
prefix_rule(pattern=["hive", "msg", "pub"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "hive msg"], decision="allow")
prefix_rule(pattern=["zsh", "-lc", "hive msg"], decision="allow")
prefix_rule(pattern=["hive", "hc"], decision="allow")
