prefix_rule(pattern=["hive", "msg"], decision="allow")
prefix_rule(pattern=["hive", "msg", "pub"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "hive msg"], decision="allow")
prefix_rule(pattern=["zsh", "-lc", "hive msg"], decision="allow")
prefix_rule(pattern=["hive", "hc"], decision="allow")

# forbidden: mirror of claude permissions.deny
prefix_rule(pattern=["rm", "-rf"], decision="forbidden", justification="destructive recursive delete")
prefix_rule(pattern=["wget"], decision="forbidden", justification="prefer curl; wget pulls arbitrary URLs")
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden", justification="use --force-with-lease")
prefix_rule(pattern=["git", "reset", "--hard"], decision="forbidden", justification="loses uncommitted work")
prefix_rule(pattern=["sops", "-d"], decision="forbidden", justification="no decrypting secrets")
prefix_rule(pattern=["sops", "--decrypt"], decision="forbidden", justification="no decrypting secrets")

# .env protection (shell-reader best-effort; sandbox cannot block codex's native file-view tool)
prefix_rule(pattern=["cat", ".env"], decision="forbidden", justification="no reading env files")
prefix_rule(pattern=["bat", ".env"], decision="forbidden", justification="no reading env files")
prefix_rule(pattern=["less", ".env"], decision="forbidden", justification="no reading env files")
prefix_rule(pattern=["head", ".env"], decision="forbidden", justification="no reading env files")
prefix_rule(pattern=["tail", ".env"], decision="forbidden", justification="no reading env files")
