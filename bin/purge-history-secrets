#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
#
# purge-history-secrets: Scan ~/.zsh_history with TruffleHog and redact
# detected secrets in place, replacing values with [REDACTED].
#
# Usage:
#   purge-history-secrets           # scan and redact in place
#   purge-history-secrets --dry-run # show what would be redacted, no changes

import argparse
import json
import logging
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

LOG_FILE = Path.home() / ".local" / "dotlogs" / "purge-history-secrets.log"
TRUFFLEHOG_CONFIG = Path.home() / ".config" / "trufflehog" / "config.yaml"

RESET  = "\033[0m"
BOLD   = "\033[1m"
RED    = "\033[0;31m"
GREEN  = "\033[0;32m"
YELLOW = "\033[1;33m"
CYAN   = "\033[0;36m"


class ConsoleAndFileHandler(logging.Handler):
    """Emit records to the terminal (colorized) and to a log file (plain)."""

    COLORS = {
        "INFO":    GREEN,
        "WARNING": YELLOW,
        "ERROR":   RED,
        "DRY":     CYAN,
        "FOUND":   RED,
    }

    def __init__(self, log_file: Path) -> None:
        super().__init__()
        log_file.parent.mkdir(parents=True, exist_ok=True)
        self._file = log_file.open("a")

    def emit(self, record: logging.LogRecord) -> None:
        ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        level = record.levelname
        msg = record.getMessage()

        color = self.COLORS.get(level, RESET)
        print(f"{color}[{level.lower()}]{RESET} {msg}")
        self._file.write(f"{ts} [{level.lower()}] {msg}\n")
        self._file.flush()


# Register custom levels so callers can do log.found(...) / log.dry(...)
DRY_LEVEL   = 25
FOUND_LEVEL = 35
logging.addLevelName(DRY_LEVEL,   "DRY")
logging.addLevelName(FOUND_LEVEL, "FOUND")


class Logger(logging.Logger):
    def dry(self, msg: str, *args, **kwargs) -> None:
        self._log(DRY_LEVEL, msg, args, **kwargs)

    def found(self, msg: str, *args, **kwargs) -> None:
        self._log(FOUND_LEVEL, msg, args, **kwargs)


logging.setLoggerClass(Logger)
log: Logger = logging.getLogger("purge-history-secrets")  # type: ignore[assignment]
log.setLevel(logging.DEBUG)


def setup_logging() -> None:
    log.addHandler(ConsoleAndFileHandler(LOG_FILE))


# ---------------------------------------------------------------------------
# TruffleHog
# ---------------------------------------------------------------------------

def check_dependencies() -> None:
    for cmd in ("trufflehog",):
        if not shutil.which(cmd):
            sys.exit(f"Error: '{cmd}' is not installed. Run: brew install {cmd}")


def scan(hist: Path) -> list[dict]:
    """Run trufflehog and return a list of {detector, raw} findings."""
    cmd = ["trufflehog", "filesystem", str(hist), "--json", "--no-update"]
    if TRUFFLEHOG_CONFIG.exists():
        cmd += ["--config", str(TRUFFLEHOG_CONFIG)]

    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
    )

    findings = []
    seen_raws: set[str] = set()

    for line in result.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue

        raw  = obj.get("Raw", "")
        name = obj.get("DetectorName", "unknown")
        if raw and raw not in seen_raws:
            seen_raws.add(raw)
            findings.append({"detector": name, "raw": raw})

    # Drop any raw value that is a substring of a longer raw — the longer
    # replacement will cover it, so keeping both would be redundant.
    raws = [f["raw"] for f in findings]
    return [
        f for f in findings
        if not any(f["raw"] in other for other in raws if other != f["raw"])
    ]


# ---------------------------------------------------------------------------
# Redaction
# ---------------------------------------------------------------------------

PREVIEW_WIDTH = 120


def matching_lines(lines: list[str], secret: str) -> list[tuple[int, str]]:
    """Return (1-based line number, line) pairs containing the secret."""
    return [(i + 1, line) for i, line in enumerate(lines) if secret in line]


def preview_line(line: str, secret: str) -> str:
    """Return the line with the secret masked and the whole thing truncated."""
    masked = line.replace(secret, "[REDACTED]")
    # Strip the zsh extended history prefix ": timestamp:0;" for readability
    if masked.startswith(": ") and ";" in masked[:30]:
        masked = masked.split(";", 1)[-1]
    masked = masked.strip()
    if len(masked) > PREVIEW_WIDTH:
        masked = masked[:PREVIEW_WIDTH] + "…"
    return masked


def redact(hist: Path, backup: Path, findings: list[dict], dry_run: bool) -> None:
    content = hist.read_text(errors="surrogateescape")
    lines   = content.splitlines()

    actionable = []
    for f in findings:
        matches = matching_lines(lines, f["raw"])
        if not matches:
            log.warning(f"{f['detector']} — detected but not matched verbatim (manual review recommended)")
            continue
        f["matches"] = matches
        actionable.append(f)

    if not actionable:
        log.warning("no verbatim matches found — no changes made")
        return

    total = sum(len(f["matches"]) for f in actionable)

    for f in actionable:
        count = len(f["matches"])
        if dry_run:
            log.dry(f"{f['detector']} — {count} occurrence(s) would be redacted")
            for lineno, line in f["matches"]:
                log.dry(f"  line {lineno}: {preview_line(line, f['raw'])}")
        else:
            log.found(f"{f['detector']} — {count} occurrence(s) redacted")

    if dry_run:
        log.dry(f"scan complete: {total} occurrence(s) across {len(actionable)} secret(s) would be redacted")
        return

    # Backup then redact — longest raw first so shorter overlapping matches
    # don't partially redact before the full token gets a chance to match.
    shutil.copy2(hist, backup)
    log.info(f"backup written: {backup}")

    for f in sorted(actionable, key=lambda f: len(f["raw"]), reverse=True):
        content = content.replace(f["raw"], "[REDACTED]")  # type: ignore[arg-type]

    hist.write_text(content, errors="surrogateescape")
    log.info(f"scan complete: {total} occurrence(s) redacted across {len(actionable)} secret(s)")
    log.info(f"restore backup with: cp {backup} {hist}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Scan ~/.zsh_history with TruffleHog and redact secrets in place.",
    )
    parser.add_argument(
        "--dry-run", "-n",
        action="store_true",
        help="Show what would be redacted without making changes.",
    )
    parser.add_argument(
        "--history",
        type=Path,
        default=Path(os.environ.get("HISTFILE", Path.home() / ".zsh_history")),
        help="Path to history file (default: $HISTFILE or ~/.zsh_history).",
    )
    args = parser.parse_args()

    setup_logging()
    check_dependencies()

    hist: Path   = args.history
    backup: Path = hist.with_suffix(".bak")

    if not hist.exists():
        sys.exit(f"Error: history file not found: {hist}")

    if args.dry_run:
        log.warning("dry run — no changes will be made")

    log.info(f"scan started: {hist}")

    findings = scan(hist)

    if not findings:
        log.info("scan complete: no secrets detected")
        return

    log.found(f"{len(findings)} unique secret(s) detected")
    redact(hist, backup, findings, dry_run=args.dry_run)


if __name__ == "__main__":
    main()
