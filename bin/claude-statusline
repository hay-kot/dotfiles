#!/bin/bash
# Claude Code status line - custom Pi footer

input=$(cat)

# Parse JSON
ctx_used=$(echo "$input" | jq -r '.context_window.total_input_tokens // empty' 2>/dev/null)
ctx_total=$(echo "$input" | jq -r '.context_window.context_window_size // empty' 2>/dev/null)
ctx_pct=$(echo "$input" | jq -r '.context_window.used_percentage // empty' 2>/dev/null | cut -d. -f1)
model=$(echo "$input" | jq -r '.model.id // empty' 2>/dev/null)
thinking=$(echo "$input" | jq -r '.effort.level // empty' 2>/dev/null)

# Colors
R=$'\033[0m'
DIM=$'\033[2m'
ACCENT=$'\033[96m'
MUTED=$'\033[37m'
WARN=$'\033[33m'
ERR=$'\033[31m'

icon_branch=$(printf '\xee\x9c\xa5')  # U+E725

abbrev() {
    local n=$1
    [[ "$n" =~ ^[0-9]+$ ]] || { echo "?"; return; }
    if   (( n >= 1000000 )); then printf '%dm' $(( n / 1000000 ))
    elif (( n >= 1000    )); then printf '%dk' $(( n / 1000 ))
    else                          printf '%d'  "$n"
    fi
}

# Git branch
branch=""
git rev-parse --git-dir &>/dev/null && \
    branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)

if [ -n "$branch" ]; then
    line_c="${ACCENT}${icon_branch} ${branch}${R}"
else
    line_c="${DIM}no branch${R}"
fi

sep_c="${MUTED}  ·  ${R}"

# Context usage
if [ -n "$ctx_used" ] && [ -n "$ctx_total" ]; then
    u=$(abbrev "$ctx_used")
    t=$(abbrev "$ctx_total")
    tokens="${u}/${t}"
    if [[ "$ctx_pct" =~ ^[0-9]+$ ]]; then
        (( ctx_pct >= 75 )) && pc="$ERR" || { (( ctx_pct >= 65 )) && pc="$WARN" || pc="$MUTED"; }
        line_c+="${sep_c}${MUTED}${tokens}${R} ${pc}${ctx_pct}%${R}"
    else
        line_c+="${sep_c}${MUTED}${tokens}${R}"
    fi
else
    line_c+="${sep_c}${MUTED}ctx ?${R}"
fi

# Model
if [ -n "$model" ]; then
    line_c+="${sep_c}${MUTED}${model}${R}"
else
    line_c+="${sep_c}${MUTED}no model${R}"
fi

# Thinking effort
if [ -n "$thinking" ]; then
    line_c+="${sep_c}${MUTED}${thinking}${R}"
fi

printf ' %s\n' "$line_c"
